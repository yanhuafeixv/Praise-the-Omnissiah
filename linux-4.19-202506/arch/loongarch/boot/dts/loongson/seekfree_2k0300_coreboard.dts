// ----------电机PWM配置---------- //
// 电机信号1
// DIR_GPIO73
// GPIO86
&pwm0{
    status = "okay";
    pinctrl-names = "default";
    pinctrl-0 = <&pwm0_mux_m1>;
    clock-frequency = <160000000>;
    compatible = "loongson,ls300-pwm";
};

// 电机信号2
// DIR_GPIO76
// GPIO87
&pwm1{
    status = "okay";
    pinctrl-names = "default";
    pinctrl-0 = <&pwm1_mux_m1>;
    clock-frequency = <160000000>;
    compatible = "loongson,ls300-pwm";
};

// 舵机信号
// GPIO88
&pwm2{
    status = "okay";
    pinctrl-names = "default";
    pinctrl-0 = <&pwm2_mux_m1>;
    clock-frequency = <160000000>;
    compatible = "loongson,ls300-pwm";
};

// 电调信号
// GPIO89
&pwm3{
    status = "okay";
    pinctrl-names = "default";
    pinctrl-0 = <&pwm3_mux_m1>;
    clock-frequency = <160000000>;
    compatible = "loongson,ls300-pwm";
};
// ----------电机PWM配置---------- //




// ----------ADC配置----------//
&adc{
	status = "okay";
};
